# Private key of the deployer wallet (no 0x prefix)
ACCOUNT_PRIVATE_KEY=your_account_private_key_here

# Snowtrace API key for contract verification on Avalanche
# Get one at https://snowtrace.io/myapikey
SNOWTRACE_API_KEY=your_snowtrace_api_key_here

# Optional: override default public RPC endpoints
# AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
# FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# ── Deployment parameters ─────────────────────────────────────────────────────

# Address that receives the 2% protocol fee from all pools
PROTOCOL_TREASURY=your_treasury_address_here

# Default swap fee in basis points applied to all new pools (100 = 1%)
DEFAULT_SWAP_FEE_BPS=100
